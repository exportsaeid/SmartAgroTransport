<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"
            android:layoutDirection="ltr"
            android:orientation="horizontal">
            <!-- فلش برگشت -->
            <ImageView
                android:id="@+id/backButtonPish"
                android:layout_width="90dp"
                android:layout_height="30dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="برگشت"
                android:layoutDirection="ltr"
                android:src="@drawable/ic_arrow_back" />
            <!-- عنوان پیش‌نمایش -->
            <TextView
                android:layout_width="250dp"
                android:layout_height="40dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="پیش‌نمایش فاکتور"
                android:textColor="#1976d2"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:layoutDirection="rtl"
            android:orientation="vertical">


            <!-- اطلاعات مشتری و تاریخ -->
            <TextView
                android:id="@+id/tvPreviewCustomer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingRight="12dp"
                android:text="مشتری: نام مشتری - تماس: شماره تماس"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvPreviewDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:paddingRight="12dp"
                android:text="تاریخ: ۱۴۰۴/۱۰/۰۱"
                android:textSize="16sp" />
        </LinearLayout>

<!--        <HorizontalScrollView-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="8dp"-->
<!--            android:scrollbars="vertical">-->


            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="140dp"
                android:layout_marginBottom="100dp"
                android:scrollbarTrackVertical="@id/tableItems"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- هدر جدول -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:background="#1976d2"
                        android:orientation="horizontal"
                        android:textAlignment="textEnd"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="ردیف"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="180dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="نام محصول"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="وزن"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="قیمت واحد"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="نام فروشنده"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="موبایل"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="آدرس"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="جمع "
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>


                    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#f5f5f5"
                        android:layoutDirection="rtl">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="450dp"
                        android:layout_marginTop="0dp"
                        android:orientation="horizontal">

                        <!-- جدول آیتم‌ها (پر می‌شود در کد جاوا) -->
                        <TableLayout
                            android:id="@+id/tableItems"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAlignment="center"
                            android:textDirection="ltr"
                            android:layoutDirection="rtl"
                            android:background="#FFFFFF"
                            android:stretchColumns="*" />
                        <!-- جمع کل فاکتور -->

                    </LinearLayout>
                    </ScrollView>
                </LinearLayout>
            </HorizontalScrollView>
<!--        </HorizontalScrollView>-->

        <LinearLayout
            android:id="@+id/bottomActionContainer"
            android:layout_width="match_parent"
            android:layout_height="105dp"
            android:layout_alignParentBottom="true"
            android:background="#FFFFFF"
            android:elevation="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPreviewTotal"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#e8f5e9"
                android:gravity="start"
                android:paddingTop="8dp"

                android:text="جمع کل قابل پرداخت: ۰ تومان"
                android:paddingRight="8dp"
                android:textColor="#d32f2f"
                android:textSize="16sp"
                android:textStyle="bold" />
            <!-- دکمه صدور PDF فاکتور -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_export_pdf"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="صدور PDF فاکتور"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart"
                app:iconPadding="16dp" />

        </LinearLayout>

    </RelativeLayout>
</androidx.drawerlayout.widget.DrawerLayout>